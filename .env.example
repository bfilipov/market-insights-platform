# ==========================================
# Market Data Service Configuration
# ==========================================

# Server Configuration
MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8001

# Internal Authentication
# Used by API Gateway Service to authenticate requests to this service
MARKET_DATA_INTERNAL_API_KEY=internal-service-key-market-data

# Provider Configuration
# Sets the default data provider. Options: "coingecko" or "coincap"
MARKET_DATA_DEFAULT_PROVIDER=coingecko

# External Provider URLs
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINCAP_BASE_URL=https://rest.coincap.io/v3

# External Provider URLs
COINCAP_API_KEY="your-coincap-api-key" # A free API key should be generated from https://pro.coincap.io/dashboard

# Resilience Configuration
# Timeout in seconds for external API calls
MARKET_DATA_REQUEST_TIMEOUT=10
# Maximum number of retry attempts for transient network errors
MARKET_DATA_MAX_RETRIES=3

# ==========================================
# Api Gateway Service Configuration
# ==========================================

API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_API_KEY="your-secure-api-key-here"  # Should be changed before use

MARKET_DATA_SERVICE_URL=http://market_data:8001


LOG_LEVEL=INFO